rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(businessId) {
      return isAuth()
        && exists(/databases/$(database)/documents/userBusiness/$(businessId))
        && get(/databases/$(database)/documents/userBusiness/$(businessId)).data.ownerUid == request.auth.uid;
    }

    // Ensure businessId cannot be changed on updates
    function businessIdUnchanged() {
      return request.resource.data.businessId == resource.data.businessId;
    }

    // ─── User & Business collections ────────────────────────────

    match /userBusiness/{businessId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isOwner(businessId);
      allow delete: if false;
    }

    match /userRole/{roleId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false;
    }

    match /businessConfig/{configId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    // ─── Business-scoped collections ────────────────────────────
    // All require authentication.
    // businessId is immutable after creation.
    // Immutable collections block updates/deletes.

    match /product/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    match /productCategory/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if isAuth();
    }

    match /inventory/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    match /inventoryMovement/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    match /sale/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    match /settlement/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    match /debt/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    match /wallet/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    match /cashRegister/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    match /dailyCashSnapshot/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    match /dailyCashTransaction/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    match /globalCash/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    match /purchaseInvoice/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    match /client/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    match /pet/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    match /supplier/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    match /paymentMethod/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    match /paymentProvider/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    match /ownersAccount/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && businessIdUnchanged();
      allow delete: if false;
    }

    // Legacy collections (SaleRegisterDetails.vue raw queries)
    match /salesRegisterExpense/{docId} {
      allow read:   if isAuth();
      allow write:  if false;
    }
  }
}
